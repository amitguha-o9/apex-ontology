// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth tables ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(VIEWER)
  accounts      Account[]
  sessions      Session[]
  changes       Change[]
  createdAt     DateTime  @default(now())
}

enum UserRole {
  VIEWER
  EDITOR
  ADMIN
}

// ─── Ontology tables ──────────────────────────────────────────────────────────

model OntologyModel {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  color       String           @default("#6366f1")
  sortOrder   Int              @default(0)
  subModels   OntologySubModel[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model OntologySubModel {
  id          String          @id @default(cuid())
  name        String
  modelId     String
  model       OntologyModel   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  entities    OntologyEntity[]
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([modelId, name])
}

model OntologyEntity {
  id          String              @id @default(cuid())
  name        String
  description String?             @db.Text
  modelType   String?
  subModelId  String
  subModel    OntologySubModel    @relation(fields: [subModelId], references: [id], onDelete: Cascade)
  attributes  OntologyAttribute[]
  // Relationships stored as JSON for flexibility; validated at app layer
  relationships Json              @default("[]")
  annotations   Json              @default("{}")
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([subModelId, name])
}

model OntologyAttribute {
  id          String         @id @default(cuid())
  name        String
  type        String         @default("String")
  required    Boolean        @default(false)
  description String?
  notes       String?
  sortOrder   Int            @default(0)
  entityId    String
  entity      OntologyEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ─── Audit log ────────────────────────────────────────────────────────────────

model Change {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  action      ChangeAction
  entityType  String     // "Model" | "SubModel" | "Entity" | "Attribute" | "Relationship"
  entityId    String
  entityName  String
  before      Json?
  after       Json?
  createdAt   DateTime   @default(now())
}

enum ChangeAction {
  CREATE
  UPDATE
  DELETE
  MOVE
}
